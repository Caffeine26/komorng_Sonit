{
  "name": "@xfos/backend-api",
  "version": "0.1.0",
  "private": true,
  "description": "XFOS backend — NestJS modular monolith with hexagonal domains",
  "scripts": {
    "dev": "nest start --watch",
    "build": "pnpm --filter @xfos/database prisma:generate && nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:unit": "vitest run --dir src --passWithNoTests",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/lib-storage": "^3.1047.0",
    "@nestjs/common": "10.4.1",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.4.1",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "10.4.1",
    "@nestjs/throttler": "^6.5.0",

    "@xfos/contracts-bff-admin": "workspace:*",
    "@xfos/contracts-bff-platform-admin": "workspace:*",
    "@xfos/contracts-bff-storefront": "workspace:*",
    "@xfos/contracts-billing": "workspace:*",
    "@xfos/contracts-catalog": "workspace:*",
    "@xfos/contracts-enums": "workspace:*",

    "@xfos/contracts-tenant": "workspace:*",
    "@xfos/database": "workspace:*",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "jsonwebtoken": "9.0.2",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "9.3.2",
    "pino-http": "10.2.0",
    "puppeteer": "^25.1.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.4",
    "@nestjs/schematics": "10.1.4",
    "@nestjs/testing": "10.4.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "20.14.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.0",
    "supertest": "7.0.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  }
}
