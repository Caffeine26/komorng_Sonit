# ============================================================================
# XFOS — Root reference .env
# Copy to .env.local at the repo root (NOT the app roots). Each workspace
# reads the variables it needs from process.env.
# ============================================================================

NODE_ENV=development

# ----------------------------------------------------------------------------
# Database (infra/docker-compose.yml exposes these ports)
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://xfos:xfos@localhost:5432/xfos?schema=public
TEST_DATABASE_URL=postgresql://xfos:xfos@localhost:5433/xfos_test?schema=public

# ----------------------------------------------------------------------------
# Redis (queues, rate limit, socket.io adapter later)
# ----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# Backend API
# ----------------------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:4000
JWT_ACCESS_SECRET=change-me-in-production-access
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
LOG_LEVEL=debug

# ----------------------------------------------------------------------------
# Frontend apps — NEXT_PUBLIC_* is visible to the browser.
# Each app reads what it needs from these.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000
NEXT_PUBLIC_KITCHEN_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_PLATFORM_ADMIN_URL=http://localhost:3003

# ----------------------------------------------------------------------------
# ABA PayWay (leave blank for local dev)
# ----------------------------------------------------------------------------
ABA_MERCHANT_ID=
ABA_API_KEY=
ABA_BASE_URL=https://checkout-sandbox.payway.com.kh

# ----------------------------------------------------------------------------
# Observability (optional in dev)
# ----------------------------------------------------------------------------
SENTRY_DSN=
